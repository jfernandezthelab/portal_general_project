// Peak CU — Initiatives Portal
// Generated: 2026-04-03
// Project: 26.195.02 · The Lab Consulting

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum InitiativeType {
  RPA_BOT
  PIR
  DASHBOARD
}

enum InitiativeStatus {
  IN_PROGRESS
  CLIENT_READY
  EARLY_ESTIMATE
  DE_PRIORITIZED
}

enum Workstream {
  CONSUMER
  COMMERCIAL_SB
  BACK_OFFICE
  LOAN_SERVICING
  EXECUTIVE
  ALL
}

enum SystemFlag {
  NONE
  SYS_IMPACT
  SYS_BLOCKED
  ORG_CHANGE
}

enum UserRole {
  ADMIN
  CONSULTANT
  CLIENT_VIEWER
  CLIENT_EDITOR
}

enum ProjectStatus {
  ON_TRACK
  AT_RISK
  DELAYED
  COMPLETE
}

enum ChangeStatus {
  ACTIVE
  RESOLVED
  MONITORING
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETE
  BLOCKED
}

enum SprintStatus {
  PLANNED
  ACTIVE
  COMPLETE
}

// ─────────────────────────────────────────────
// CLIENTS
// ─────────────────────────────────────────────

model Client {
  id           String   @id @default(cuid())
  name         String
  industry     String?
  contactName  String?
  contactEmail String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  users                User[]
  settings             Settings?
  initiatives          Initiative[]
  kpis                 Kpi[]
  milestones           Milestone[]
  sprints              Sprint[]
  systemChanges        SystemChange[]

  @@map("clients")
}

// ─────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  clientId     String
  email        String   @unique
  name         String
  role         UserRole @default(CLIENT_VIEWER)
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("users")
}

// ─────────────────────────────────────────────
// SETTINGS  (one per client)
// ─────────────────────────────────────────────

model Settings {
  id          String        @id @default(cuid())
  clientId    String        @unique
  progress    Int           @default(0)     // 0–100 overall project %
  status      ProjectStatus @default(ON_TRACK)
  totalWeeks  Int           @default(0)
  createdAt   DateTime      @default(now())
  lastUpdated DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("settings")
}

// ─────────────────────────────────────────────
// INITIATIVES  (RPA Bots · PIRs · Dashboards)
// ─────────────────────────────────────────────

model Initiative {
  id              String           @id @default(cuid())
  clientId        String
  name            String
  type            InitiativeType
  workstream      Workstream
  status          InitiativeStatus @default(IN_PROGRESS)
  estBenefitMin   Float?           // annual $ low end
  estBenefitMax   Float?           // annual $ high end
  benefitLabel    String?          // e.g. "$33K–$86K" (raw label from Excel)
  volume          String?          // e.g. "480–1,248 units/mo"
  systemFlag      SystemFlag       @default(NONE)
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Relations
  client          Client                    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  kpis            Kpi[]
  milestones      Milestone[]
  systemChanges   InitiativeSystemChange[]

  @@map("initiatives")
}

// ─────────────────────────────────────────────
// KPIs  (metrics per initiative)
// ─────────────────────────────────────────────

model Kpi {
  id           String   @id @default(cuid())
  clientId     String
  initiativeId String
  label        String   // e.g. "Pull-through rate"
  value        String   // stored as string to support ranges & text
  unit         String?  // e.g. "%", "hrs", "FTE"
  category     String?  // e.g. "throughput", "capacity", "quality"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  client      Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  initiative  Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)

  @@map("kpis")
}

// ─────────────────────────────────────────────
// MILESTONES
// ─────────────────────────────────────────────

model Milestone {
  id           String          @id @default(cuid())
  clientId     String
  initiativeId String?         // null = project-level milestone
  title        String
  status       MilestoneStatus @default(PENDING)
  dueDate      DateTime?
  completedAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  // Relations
  client     Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  initiative Initiative? @relation(fields: [initiativeId], references: [id], onDelete: SetNull)

  @@map("milestones")
}

// ─────────────────────────────────────────────
// SPRINTS
// ─────────────────────────────────────────────

model Sprint {
  id           String       @id @default(cuid())
  clientId     String
  sprintNumber Int
  startDate    DateTime
  endDate      DateTime
  status       SprintStatus @default(PLANNED)
  goals        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relations
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, sprintNumber])
  @@map("sprints")
}

// ─────────────────────────────────────────────
// SYSTEM CHANGES  (blockers & platform shifts)
// ─────────────────────────────────────────────

model SystemChange {
  id                  String       @id @default(cuid())
  clientId            String
  title               String       // e.g. "Origence → MeridianLink"
  impactSummary       String
  recommendedAction   String
  status              ChangeStatus @default(ACTIVE)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  // Relations
  client       Client                   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  initiatives  InitiativeSystemChange[]

  @@map("systemChanges")
}

// ─────────────────────────────────────────────
// JOIN: initiatives ↔ system changes  (M-to-M)
// ─────────────────────────────────────────────

model InitiativeSystemChange {
  id             String @id @default(cuid())
  initiativeId   String
  systemChangeId String

  // Relations
  initiative   Initiative   @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  systemChange SystemChange @relation(fields: [systemChangeId], references: [id], onDelete: Cascade)

  @@unique([initiativeId, systemChangeId])
  @@map("initiativeSystemChanges")
}
